# ═══════════════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE — SISTEMA BOM BEEF
# Copie este arquivo para .env e preencha os valores
# No Railway: configure via Dashboard > Variables
# ═══════════════════════════════════════════════════════════════

# ── Banco de dados ───────────────────────────────────────────
# Railway injeta automaticamente DATABASE_URL ao adicionar o plugin PostgreSQL
# Formato: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Autenticação JWT ─────────────────────────────────────────
# Gere uma string aleatória forte (min 32 chars):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque_por_uma_string_secreta_muito_longa_e_aleatoria

# ── Ambiente ─────────────────────────────────────────────────
NODE_ENV=production

# ── Porta (Railway define automaticamente via PORT) ──────────
# PORT=3000  <- Railway define isso, não precisa setar

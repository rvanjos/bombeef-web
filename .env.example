# ── Banco de dados ────────────────────────────────────────────────────────────
# Railway fornece DATABASE_URL automaticamente.
# Para desenvolvimento local, preencha abaixo:
DATABASE_URL=postgresql://usuario:senha@localhost:5432/bombeef

# ── Autenticação ──────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque_por_uma_string_aleatoria_longa_aqui
JWT_EXPIRES_IN=8h

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_MAX_MB=15

# ── Admin inicial (usado pelo seed.js) ────────────────────────────────────────
ADMIN_NOME=Administrador
ADMIN_EMAIL=admin@bombeef.com.br
ADMIN_SENHA=BomBeef@2024
